{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "compile"],
      "problemMatcher": "$tsc",
      "group": "build"
    },
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "watch"],
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    }
  ]
}
